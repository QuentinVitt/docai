{
  "app": {
    "name": "docai",
    "version": "0.1.0",
    "environment": "production"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "cors": {
      "origins": ["https://example.com"],
      "methods": ["GET", "POST", "PUT", "DELETE"],
      "allow_credentials": true
    }
  },
  "llm": {
    "providers": [
      {
        "name": "anthropic",
        "models": ["claude-sonnet-4-6", "claude-haiku-4-5-20251001"],
        "default": "claude-sonnet-4-6"
      },
      {
        "name": "openai",
        "models": ["gpt-4o"],
        "default": "gpt-4o"
      }
    ],
    "retry": {
      "max_attempts": 3,
      "backoff_factor": 2
    }
  },
  "features": {
    "tree_sitter": true,
    "heuristic_extraction": true,
    "llm_fallback": true,
    "doc_generation": false
  }
}
